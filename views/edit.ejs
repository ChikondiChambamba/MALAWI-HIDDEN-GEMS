<%- include('partials/header') %>

<section class="mx-auto max-w-4xl">
  <div class="surface-panel p-8 md:p-10">
    <div class="max-w-2xl">
      <p class="eyebrow">Editor mode</p>
      <h1 class="mt-4 font-display text-5xl leading-none text-ink-900">Refine your destination story.</h1>
      <p class="mt-5 text-base leading-8 text-ink-700">Update the content, map coordinates, tags, and imagery while keeping the same post ownership token.</p>
    </div>

    <% if (typeof error !== 'undefined') { %>
      <div class="mt-6 rounded-[1.6rem] border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
        <%= error %>
      </div>
    <% } %>

    <form action="/posts/<%= post.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="mt-8 grid gap-8">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="md:col-span-2">
          <label for="title" class="mb-2 block text-sm font-semibold text-ink-900">Story title</label>
          <input type="text" id="title" name="title" value="<%= form.title %>" required class="w-full rounded-[1.4rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm text-ink-900 outline-none focus:border-forest-300 focus:bg-white">
        </div>
        <div>
          <label for="authorName" class="mb-2 block text-sm font-semibold text-ink-900">Your name</label>
          <input type="text" id="authorName" name="authorName" value="<%= form.authorName %>" placeholder="Anonymous traveler" class="w-full rounded-[1.4rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm text-ink-900 outline-none focus:border-forest-300 focus:bg-white">
        </div>
        <div>
          <label for="location" class="mb-2 block text-sm font-semibold text-ink-900">Location in Malawi</label>
          <input type="text" id="location" name="location" value="<%= form.location %>" placeholder="Cape Maclear, Mulanje, Zomba..." class="w-full rounded-[1.4rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm text-ink-900 outline-none focus:border-forest-300 focus:bg-white">
        </div>
        <div>
          <label for="latitude" class="mb-2 block text-sm font-semibold text-ink-900">Latitude</label>
          <input type="number" step="any" id="latitude" name="latitude" value="<%= form.latitude ?? '' %>" class="w-full rounded-[1.4rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm text-ink-900 outline-none focus:border-forest-300 focus:bg-white">
        </div>
        <div>
          <label for="longitude" class="mb-2 block text-sm font-semibold text-ink-900">Longitude</label>
          <input type="number" step="any" id="longitude" name="longitude" value="<%= form.longitude ?? '' %>" class="w-full rounded-[1.4rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm text-ink-900 outline-none focus:border-forest-300 focus:bg-white">
        </div>
      </div>

      <div>
        <label for="image" class="mb-2 block text-sm font-semibold text-ink-900">Destination image</label>
        <% if (post.imagePath) { %>
          <img src="<%= post.imageUrl %>" alt="Current image" class="mb-4 h-64 w-full rounded-[1.6rem] object-cover" loading="lazy">
        <% } %>
        <input type="file" id="image" name="image" accept=".jpg,.jpeg,.png,.gif,.webp,image/*" class="block w-full rounded-[1.4rem] border border-dashed border-black/15 bg-sand-50 px-5 py-4 text-sm text-ink-700 file:mr-4 file:rounded-full file:border-0 file:bg-forest-600 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-forest-700">
        <p class="mt-3 text-sm leading-7 text-ink-700">Leave the file field empty to keep the current optimized Cloudinary image.</p>
        <div class="mt-4" id="imagePreview" aria-hidden="true">
          <img src="" alt="Selected image preview" id="imagePreviewTag" class="hidden h-64 w-full rounded-[1.6rem] object-cover">
        </div>
      </div>

      <div>
        <label for="content" class="mb-2 block text-sm font-semibold text-ink-900">Story content</label>
        <textarea id="content" name="content" rows="8" required class="min-h-[220px] w-full rounded-[1.6rem] border border-black/10 bg-sand-50 px-5 py-4 text-sm leading-7 text-ink-900 outline-none focus:border-forest-300 focus:bg-white"><%= form.content %></textarea>
      </div>

      <div>
        <p class="mb-3 text-sm font-semibold text-ink-900">Tags</p>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <% tags.forEach((tag) => { %>
            <label class="flex cursor-pointer items-center gap-3 rounded-[1.3rem] border border-black/10 bg-sand-50 px-4 py-3 text-sm font-medium text-ink-800 transition hover:border-forest-200 hover:bg-white">
              <input type="checkbox" name="tagSlugs" value="<%= tag.slug %>" <%= form.tagSlugs.includes(tag.slug) ? 'checked' : '' %> class="h-4 w-4 rounded border-black/20 text-forest-600 focus:ring-forest-300">
              <span><%= tag.name %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="flex flex-col gap-3 border-t border-black/5 pt-6 sm:flex-row">
        <button type="submit" class="inline-flex items-center justify-center rounded-full bg-forest-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-forest-600/20 hover:bg-forest-700">Save changes</button>
        <a href="/posts/<%= post.id %>" class="inline-flex items-center justify-center rounded-full border border-black/10 px-6 py-3 text-sm font-semibold text-ink-800 hover:border-forest-200 hover:text-forest-700">Cancel</a>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
