<%- include('partials/header') %>

<section class="form-section">
  <h2>Edit Post</h2>

  <% if (typeof error !== 'undefined') { %>
    <div class="error-message">
      <p><%= error %></p>
    </div>
  <% } %>

  <form action="/posts/<%= post.id %>?_method=PUT" method="POST" class="post-form" enctype="multipart/form-data">
    <input type="hidden" name="editorToken" value="<%= editorToken %>" id="editorTokenField">

    <div class="form-group">
      <label for="title">Title:</label>
      <input type="text" id="title" name="title" value="<%= form.title %>" required>
    </div>

    <div class="form-group">
      <label for="authorName">Your Name:</label>
      <input type="text" id="authorName" name="authorName" value="<%= form.authorName %>" placeholder="Anonymous traveler">
    </div>

    <div class="form-group">
      <label for="location">Location in Malawi:</label>
      <input type="text" id="location" name="location" value="<%= form.location %>" placeholder="Cape Maclear, Mulanje, Zomba...">
    </div>

    <div class="form-group">
      <label for="image">Blog Image:</label>
      <% if (post.imagePath) { %>
        <div class="existing-images">
          <div class="existing-thumb">
            <img src="<%= post.imageUrl %>" alt="Current image">
          </div>
        </div>
      <% } %>
      <input type="file" id="image" name="image" accept=".jpg,.jpeg,.png,.gif,.webp,image/*">
      <div class="preview-stack" id="imagePreview" aria-hidden="true">
        <img src="" alt="Selected image preview" id="imagePreviewTag" class="preview-image is-hidden">
      </div>
      <small>Leave empty to keep the current image</small>
    </div>

    <div class="form-group">
      <label for="content">Content:</label>
      <textarea id="content" name="content" rows="10" required><%= form.content %></textarea>
    </div>

    <div class="form-group">
      <p class="checkbox-group__label">Tags</p>
      <div class="checkbox-grid">
        <% tags.forEach((tag) => { %>
          <label class="checkbox-pill">
            <input
              type="checkbox"
              name="tagSlugs"
              value="<%= tag.slug %>"
              <%= form.tagSlugs.includes(tag.slug) ? 'checked' : '' %>
            >
            <span><%= tag.name %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn primary">Update Post</button>
      <a href="/posts/<%= post.id %>" class="btn secondary">Cancel</a>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
