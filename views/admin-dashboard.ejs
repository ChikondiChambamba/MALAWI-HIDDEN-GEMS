<%- include('partials/header') %>

<section class="form-section admin-panel">
  <h2><i class="fas fa-user-shield"></i> Admin Dashboard</h2>
  <p>Review published posts and remove any that should no longer appear on the site.</p>

  <div class="form-actions admin-toolbar">
    <a href="/posts" class="btn secondary"><i class="fas fa-home"></i> Back to Site</a>
    <form action="/admin/logout" method="POST">
      <button type="submit" class="btn danger"><i class="fas fa-sign-out-alt"></i> Logout</button>
    </form>
  </div>

  <% if (!posts.length) { %>
    <div class="empty-state">
      <h3>No posts available</h3>
      <p>There are currently no published stories to manage.</p>
    </div>
  <% } else { %>
    <div class="admin-post-list">
      <% posts.forEach((post) => { %>
        <article class="admin-post-item">
          <div class="admin-post-item__content">
            <h3><a href="/posts/<%= post.id %>"><%= post.title %></a></h3>
            <div class="post-meta">
              <span><i class="far fa-user"></i> <%= post.authorName %></span>
              <% if (post.location) { %>
                <span><i class="fas fa-map-marker-alt"></i> <%= post.location %></span>
              <% } %>
              <span><i class="far fa-calendar"></i> <%= new Date(post.createdAt).toDateString() %></span>
            </div>
            <p class="post-excerpt"><%= post.excerpt %></p>
          </div>
          <div class="admin-post-item__actions">
            <a href="/posts/<%= post.id %>" class="btn secondary"><i class="fas fa-eye"></i> View</a>
            <a href="/posts/<%= post.id %>/edit" class="btn primary"><i class="fas fa-edit"></i> Edit</a>
            <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="delete-form">
              <button type="submit" class="btn danger"><i class="fas fa-trash"></i> Delete</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
