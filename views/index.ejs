<%- include('partials/header') %>

<section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
  <div class="surface-panel overflow-hidden p-8 md:p-12">
    <p class="eyebrow">Discover beautifully</p>
    <h1 class="mt-4 max-w-3xl font-display text-5xl leading-none text-ink-900 md:text-7xl">Premium Malawi travel discovery for curious explorers.</h1>
    <p class="mt-6 max-w-2xl text-base leading-8 text-ink-700 md:text-lg">
      Browse thoughtful stories, find destinations by region and theme, preview places on a lightweight map, and revisit previously opened pages even when the internet drops.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a href="/posts/new" class="inline-flex items-center justify-center rounded-full bg-forest-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-forest-600/20 hover:bg-forest-700">Share your experience</a>
      <a href="/posts" class="inline-flex items-center justify-center rounded-full border border-black/10 bg-sand-50 px-6 py-3 text-sm font-semibold text-ink-800 hover:border-forest-200 hover:text-forest-700">Browse every gem</a>
    </div>
  </div>

  <aside class="glass-panel flex flex-col justify-between gap-6 p-8">
    <div>
      <p class="eyebrow">Built for the real world</p>
      <ul class="mt-5 space-y-4 text-sm leading-7 text-ink-700">
        <li>Offline-ready pages powered by a stale-while-revalidate service worker.</li>
        <li>Responsive Cloudinary images optimized with Sharp before upload.</li>
        <li>Fast mobile-first browsing with low-friction search, filters, and elegant mapping.</li>
      </ul>
    </div>
    <div class="rounded-[1.6rem] bg-forest-700 p-6 text-white">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/70">Results</p>
      <p class="mt-3 font-display text-4xl"><%= pagination.totalPosts %></p>
      <p class="mt-2 text-sm text-white/80">discoverable stories and destinations across Malawi.</p>
    </div>
  </aside>
</section>

<% if (isHomePage && featuredPost) { %>
  <section class="surface-panel mt-8 grid overflow-hidden lg:grid-cols-[0.95fr_1.05fr]">
    <div class="relative min-h-[320px]">
      <img src="<%= featuredPost.imageUrl %>" alt="<%= featuredPost.title %>" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high">
      <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></div>
    </div>
    <div class="p-8 md:p-10">
      <p class="eyebrow">Hidden Gem of the Week</p>
      <h2 class="mt-4 font-display text-4xl leading-none text-ink-900 md:text-5xl"><%= featuredPost.title %></h2>
      <div class="mt-4 flex flex-wrap gap-3 text-sm text-forest-600">
        <span><%= featuredPost.authorName %></span>
        <% if (featuredPost.location) { %><span><%= featuredPost.location %></span><% } %>
        <span><%= featuredPost.readTime %></span>
      </div>
      <% if (featuredPost.tags.length) { %>
        <div class="mt-5 flex flex-wrap gap-2">
          <% featuredPost.tags.forEach((tag) => { %>
            <a href="<%= buildTagUrl(tag.slug) %>" class="rounded-full bg-sand-100 px-3 py-1 text-xs font-semibold text-forest-700 hover:bg-sand-200"><%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
      <p class="mt-6 max-w-xl text-base leading-8 text-ink-700"><%= featuredPost.excerpt %></p>
      <a href="/posts/<%= featuredPost.id %>" class="mt-8 inline-flex items-center rounded-full bg-forest-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-forest-600/20 hover:bg-forest-700">Open the feature</a>
    </div>
  </section>
<% } %>

<section class="mt-8 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
  <div class="surface-panel p-6 md:p-8">
    <div class="flex flex-col gap-5">
      <div>
        <p class="eyebrow">Search and filter</p>
        <h2 class="mt-3 font-display text-3xl text-ink-900">Find your next Malawi experience.</h2>
      </div>
      <form action="/posts/search" method="GET" class="flex flex-col gap-3 sm:flex-row">
        <label for="searchQuery" class="sr-only">Search posts</label>
        <input
          type="search"
          id="searchQuery"
          name="q"
          value="<%= searchQuery %>"
          placeholder="Search places, stories, food, wildlife..."
          class="w-full rounded-2xl border border-black/10 bg-sand-50 px-5 py-3 text-sm text-ink-800 outline-none ring-0 transition focus:border-forest-300 focus:bg-white"
        >
        <% if (activeTag) { %>
          <input type="hidden" name="tag" value="<%= activeTag.slug %>">
        <% } %>
        <button type="submit" class="rounded-2xl bg-forest-600 px-5 py-3 text-sm font-semibold text-white hover:bg-forest-700">Search</button>
      </form>
      <div class="flex flex-wrap gap-2">
        <a href="/posts" class="<%= !activeTag ? 'bg-forest-600 text-white' : 'bg-sand-100 text-ink-700 hover:bg-sand-200' %> rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em]">
          All
        </a>
        <% tags.forEach((tag) => { %>
          <a href="<%= buildTagUrl(tag.slug) %>" class="<%= activeTag && activeTag.slug === tag.slug ? 'bg-forest-600 text-white' : 'bg-sand-100 text-ink-700 hover:bg-sand-200' %> rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em]">
            <%= tag.name %>
          </a>
        <% }) %>
      </div>
      <div class="flex flex-col gap-3 rounded-[1.6rem] bg-sand-50 p-5 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm leading-7 text-ink-700"><%= totalMatchesLabel %></p>
        <% if (searchQuery || activeTag) { %>
          <a href="<%= clearFiltersUrl %>" class="inline-flex items-center rounded-full border border-black/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700 hover:border-forest-300 hover:text-forest-700">Clear filters</a>
        <% } %>
      </div>
    </div>
  </div>

  <div data-map-shell class="surface-panel overflow-hidden">
    <div class="border-b border-black/5 px-6 py-5 md:px-8">
      <p class="eyebrow">Destination map</p>
      <h2 class="mt-2 font-display text-3xl text-ink-900">Explore plotted stories across Malawi.</h2>
    </div>
    <div class="h-[320px] md:h-[420px]">
      <div class="h-full w-full" data-map-mode="collection" data-source="<%= mapEndpoint %>"></div>
    </div>
  </div>
</section>

<section class="mt-10">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="eyebrow"><%= isHomePage ? 'Fresh arrivals' : 'Explore' %></p>
      <h2 class="mt-2 font-display text-4xl text-ink-900"><%= isHomePage ? 'Latest hidden gems' : 'Filtered destinations' %></h2>
    </div>
    <p class="hidden text-sm text-ink-700 md:block">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></p>
  </div>

  <% if (!posts.length) { %>
    <div class="surface-panel mt-6 px-8 py-14 text-center">
      <p class="eyebrow">Nothing here yet</p>
      <h3 class="mt-4 font-display text-4xl text-ink-900">No gems found.</h3>
      <p class="mx-auto mt-4 max-w-xl text-base leading-8 text-ink-700"><%= noResultsMessage %></p>
      <a href="/posts/new" class="mt-8 inline-flex items-center rounded-full bg-forest-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-forest-600/20 hover:bg-forest-700">Share a destination</a>
    </div>
  <% } else { %>
    <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% posts.forEach((post) => { %>
        <article class="surface-panel overflow-hidden">
          <a href="/posts/<%= post.id %>" class="block">
            <img src="<%= post.imageUrl %>" alt="<%= post.title %>" class="h-60 w-full object-cover" loading="lazy">
          </a>
          <div class="p-6">
            <div class="flex flex-wrap gap-2">
              <% post.tags.forEach((tag) => { %>
                <a href="<%= buildTagUrl(tag.slug) %>" class="rounded-full bg-sand-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-forest-700 hover:bg-sand-200"><%= tag.name %></a>
              <% }) %>
            </div>
            <h3 class="mt-4 font-display text-3xl leading-none text-ink-900">
              <a href="/posts/<%= post.id %>" class="hover:text-forest-600"><%= post.title %></a>
            </h3>
            <div class="mt-4 flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-forest-500">
              <span><%= post.authorName %></span>
              <% if (post.location) { %><span><%= post.location %></span><% } %>
              <span><%= post.readTime %></span>
            </div>
            <p class="mt-5 text-sm leading-7 text-ink-700"><%= post.excerpt %></p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/posts/<%= post.id %>" class="inline-flex items-center rounded-full bg-forest-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-forest-700">Read story</a>
              <% if (post.canEdit) { %>
              <div class="editor-controls flex-wrap gap-3" data-post-id="<%= post.id %>">
                <a href="/posts/<%= post.id %>/edit" class="editor-edit-link inline-flex items-center rounded-full border border-black/10 px-4 py-2.5 text-sm font-semibold text-ink-800 hover:border-forest-200 hover:text-forest-700">Edit</a>
                <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="delete-form editor-delete-form" data-post-id="<%= post.id %>">
                  <button type="submit" class="inline-flex items-center rounded-full border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-700 hover:bg-red-100">Delete</button>
                </form>
              </div>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>

  <% if (pagination.totalPages > 1) { %>
    <nav class="mt-10 flex flex-col items-center justify-between gap-4 rounded-[1.8rem] border border-black/5 bg-white px-6 py-5 sm:flex-row" aria-label="Pagination">
      <% if (pagination.hasPreviousPage) { %>
        <a href="<%= pagination.previousPageUrl %>" class="inline-flex items-center rounded-full border border-black/10 px-5 py-3 text-sm font-semibold text-ink-800 hover:border-forest-200 hover:text-forest-700">Previous page</a>
      <% } else { %>
        <span class="inline-flex cursor-not-allowed items-center rounded-full border border-black/5 px-5 py-3 text-sm font-semibold text-ink-400">Previous page</span>
      <% } %>
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
      <% if (pagination.hasNextPage) { %>
        <a href="<%= pagination.nextPageUrl %>" class="inline-flex items-center rounded-full bg-forest-600 px-5 py-3 text-sm font-semibold text-white hover:bg-forest-700">Next page</a>
      <% } else { %>
        <span class="inline-flex cursor-not-allowed items-center rounded-full bg-forest-200 px-5 py-3 text-sm font-semibold text-white/80">Next page</span>
      <% } %>
    </nav>
  <% } %>
</section>

<%- include('partials/footer') %>
