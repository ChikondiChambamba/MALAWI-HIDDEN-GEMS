<%- include('partials/header') %>

<section class="form-section">
  <h2>Contact Us</h2>
  <p>Have questions about Malawi Hidden Gems? Want to share feedback or partnership ideas? We'd love to hear from you.</p>

  <% if (typeof error !== 'undefined') { %>
    <div class="error-message">
      <p><%= error %></p>
    </div>
  <% } %>

  <% if (typeof success !== 'undefined') { %>
    <div class="success-message">
      <p><%= success %></p>
    </div>
  <% } %>

  <form action="/contact" method="POST">
    <div class="form-group">
      <label for="name">Your Name</label>
      <input type="text" id="name" name="name" value="<%= form.name %>" required>
    </div>

    <div class="form-group">
      <label for="email">Email Address</label>
      <input type="email" id="email" name="email" value="<%= form.email %>" required>
    </div>

    <div class="form-group">
      <label for="message">Message</label>
      <textarea id="message" name="message" rows="6" required><%= form.message %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn primary">Send Message</button>
      <a href="/posts" class="btn secondary">Cancel</a>
    </div>
  </form>
</section>

<section class="contact-info">
  <h3>Other Ways to Reach Us</h3>
  <div class="contact-methods">
    <div class="contact-method">
      <h4>Email</h4>
      <p>info@malawitourism.com</p>
    </div>
    <div class="contact-method">
      <h4>Phone</h4>
      <p>+265 885 040 112</p>
    </div>
    <div class="contact-method">
      <h4>Address</h4>
      <p>Tourism House<br>Lilongwe, Malawi</p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
