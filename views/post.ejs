<%- include('partials/header') %>

<article class="full-post">
  <% if (issuedEditorToken) { %>
    <div
      class="success-message editor-token-notice"
      data-issued-editor-token="<%= issuedEditorToken %>"
      data-issued-post-id="<%= post.id %>"
    >
      <div>
        <strong>Your editor token has been saved in this browser.</strong>
        <p>Keep this token safe if you want a backup for editing or deleting this post later.</p>
        <code><%= issuedEditorToken %></code>
      </div>
    </div>
  <% } %>

  <h2><%= post.title %></h2>

  <div class="post-meta">
    <span><%= post.authorName %></span>
    <% if (post.location) { %>
      <span><%= post.location %></span>
    <% } %>
    <span>Shared on <%= new Date(post.createdAt).toDateString() %></span>
    <span>Updated <%= new Date(post.updatedAt).toDateString() %></span>
    <span><%= post.readTime %></span>
  </div>

  <% if (post.tags.length) { %>
    <div class="tag-list">
      <% post.tags.forEach((tag) => { %>
        <a href="/posts?tag=<%= tag.slug %>" class="tag-pill"><%= tag.name %></a>
      <% }) %>
    </div>
  <% } %>

  <% if (post.imagePath && post.imagePath !== 'default.jpg') { %>
    <div class="post-image">
      <img src="<%= post.imageUrl %>" alt="<%= post.title %>">
    </div>
  <% } %>

  <div class="post-content">
    <%- post.formattedContent %>
  </div>

  <div class="post-actions">
    <a href="/posts" class="btn secondary">Back to All Experiences</a>
    <div class="editor-controls" data-post-id="<%= post.id %>">
      <a href="/posts/<%= post.id %>/edit" class="btn primary editor-edit-link">Edit This Experience</a>
      <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="delete-form editor-delete-form" data-post-id="<%= post.id %>">
        <input type="hidden" name="editorToken" class="editor-token-field">
        <button type="submit" class="btn danger">Delete Experience</button>
      </form>
    </div>
  </div>
</article>

<%- include('partials/footer') %>
